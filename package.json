{
  "name": "spareparts-platform",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "nx": "nx",
    "dev": "nx run-many -t dev --projects=@spareparts/storefront,@spareparts/admin-panel,@spareparts/tenant-dashboard,@spareparts/api --parallel=4",
    "dev:storefront": "nx dev @spareparts/storefront",
    "dev:admin-panel": "nx dev @spareparts/admin-panel",
    "dev:tenant-dashboard": "nx dev @spareparts/tenant-dashboard",
    "dev:api": "nx dev @spareparts/api",
    "build": "nx run-many -t build --all",
    "typecheck": "nx run-many -t typecheck --all",
    "lint": "node lint.js",
    "lint:eslint": "nx run-many -t lint --all",
    "lint:fix": "echo 'Auto-fix not implemented yet. Run lint manually to see issues.'",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "clean": "git clean -fdX -e '!'",
    "prepare": "husky"
  },
  "overrides": {
    "entities": "6.0.1",
    "eslint-plugin-react-hooks": {
      "eslint": "^9.0.0"
    },
    "eslint-plugin-react": {
      "eslint": "^9.0.0"
    },
    "@angular-devkit/core": {
      "ajv": "^8.17.1"
    },
    "@nestjs/schematics": {
      "ajv": "^8.17.1"
    },
    "fork-ts-checker-webpack-plugin": {
      "ajv": "^6.12.5"
    },
    "ajv": "^8.18.0",
    "glob": "^13.0.6",
    "minimatch": "^10.2.4",
    "@tootallnate/once": "2.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@nx/eslint": "^22.6.0",
    "@eslint/js": "^9.18.0",
    "@eslint/compat": "^1.2.4",
    "@nx/js": "^22.6.0",
    "@nx/react": "^22.6.0",
    "@nx/vite": "^22.6.0",
    "@nx/web": "^22.6.0",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.18",
    "@swc/helpers": "~0.5.19",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "typescript-eslint": "^8.18.2",
    "@vitejs/plugin-react": "^4.6.2",
    "@vitest/ui": "^4.1.0",
    "ajv": "^8.18.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsdoc": "^62.8.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.1.7",
    "jiti": "2.6.1",
    "jsdom": "~29.0.0",
    "lint-staged": "^16.4.0",
    "nx": "^22.6.0",
    "prettier": "~3.8.1",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@prisma/client": "6.19.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^7.2.1",
    "glob": "^13.0.6",
    "lucide-react": "^0.577.0",
    "minimatch": "^10.2.4",
    "multer": "^2.1.1",
    "prisma": "6.19.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "ulid": "^3.0.2"
  }
}
