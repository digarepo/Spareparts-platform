{
  "name": "@spareparts/db",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "echo 'No build step for db package'",
    "generate": "prisma generate --schema=prisma/schema.prisma",
    "migrate:dev": "prisma migrate dev --schema=prisma/schema.prisma",
    "migrate:deploy": "prisma migrate deploy --schema=prisma/schema.prisma",
    "db:seed": "ts-node --transpile-only src/seed/index.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "ioredis": "5.9.2"
  },
  "devDependencies": {
    "@types/node": "^20.6.0",
    "prisma": "^6.19.0",
    "ts-node": "^10.9.1"
  }
}
